# Copy this file to .env and fill in your values
# .env is in .gitignore — never commit it

# HuggingFace token (needed only for Phase 2 LoRA on Kaggle)
# Get yours at: https://huggingface.co/settings/tokens
# Then request Llama access at: https://huggingface.co/meta-llama/Llama-3.1-8B
HF_TOKEN=hf_your_token_here

# Ollama settings (defaults work if Ollama is running locally)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# PyPI token (needed only when publishing — week 14)
# Get yours at: https://pypi.org/manage/account/token/
PYPI_TOKEN=pypi_your_token_here

# Audit database (defaults to local SQLite file)
SURA_AUDIT_DB=sqlite:///sura_audit.db
